{
  "name": "@llmtxt/next",
  "version": "0.1.1",
  "description": "Next.js App Router route handlers for llms.txt and llms-full.txt.",
  "license": "MIT",
  "author": "Recordly",
  "repository": {
    "type": "git",
    "url": "https://github.com/Muhammad-Hashim/llmstxt.git",
    "directory": "packages/next"
  },
  "homepage": "https://github.com/Muhammad-Hashim/llmstxt#readme",
  "keywords": [
    "llms",
    "llms.txt",
    "llms-full.txt",
    "llmtxt",
    "ai",
    "llm",
    "seo",
    "documentation",
    "nextjs",
    "app-router",
    "route-handler"
  ],
  "type": "commonjs",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "readme": "README.md",
  "files": [
    "lib/**/*"
  ],
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    }
  },
  "peerDependencies": {
    "next": ">=13.0.0"
  },
  "dependencies": {
    "@llmtxt/core": "^0.1.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "clean": "node ../../scripts/rmrf.js lib"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^18.19.130"
  }
}
