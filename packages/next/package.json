{
  "name": "@llmstxt/next",
  "version": "0.1.0",
  "description": "Next.js App Router route handlers for llms.txt and llms-full.txt.",
  "license": "MIT",
  "author": "Recordly",
  "type": "commonjs",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "files": [
    "lib/**/*"
  ],
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    }
  },
  "peerDependencies": {
    "next": ">=13.0.0"
  },
  "dependencies": {
    "@llmstxt/core": "^0.1.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "node ../../scripts/rmrf.js lib"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}

