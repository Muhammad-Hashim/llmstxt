{
  "name": "@llmtxt/core",
  "version": "0.1.0",
  "description": "Framework-agnostic scanner & generator for llms.txt and llms-full.txt.",
  "license": "MIT",
  "author": "Recordly",
  "repository": {
    "type": "git",
    "url": "https://github.com/Muhammad-Hashim/llmstxt.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/Muhammad-Hashim/llmstxt#readme",
  "keywords": [
    "llms",
    "llms.txt",
    "llms-full.txt",
    "llmtxt",
    "ai",
    "llm",
    "seo",
    "documentation",
    "nextjs",
    "sitemap"
  ],
  "type": "commonjs",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "readme": "README.md",
  "files": [
    "lib/**/*"
  ],
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "clean": "node ../../scripts/rmrf.js lib",
    "test": "jest -c ../../jest.config.js --selectProjects core"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
